# RUN: llc -mtriple=x86_64-unknown-linux-gnu -mattr=+fma \
# RUN:     --load=%llvmshlibdir/MulSubPass_Khokhlov_Andrey_FIIT2_BACKEND%shlibext \
# RUN:     -run-pass=fused-mul-sub-khokhlov %s -o - | FileCheck %s

# Тест 1: Проверка c - (a*b) → VFNMADD213SS
# CHECK-LABEL: name: test_scalar_ss_fma
# CHECK: bb.0.entry:
# CHECK-NOT: VMULSSrr
# CHECK-NOT: VSUBSSrr
# CHECK: %[[OUT:[a-z0-9]+]]:fr32 = VFNMADD213SSr %0, %1, %2, implicit $mxcsr
# CHECK: $xmm0 = COPY %[[OUT]]
# CHECK: RET64 implicit $xmm0

---
name:            test_scalar_ss_fma
alignment:       16
tracksRegLiveness: true
registers:
  - { id: 0, class: fr32 }
  - { id: 1, class: fr32 }
  - { id: 2, class: fr32 }
  - { id: 3, class: fr32 }
  - { id: 4, class: fr32 }
body:             |
  bb.0.entry:
    liveins: $xmm0, $xmm1, $xmm2
    %2:fr32 = COPY $xmm2
    %1:fr32 = COPY $xmm1
    %0:fr32 = COPY $xmm0
    %3:fr32 = nofpexcept VMULSSrr %0, %1, implicit $mxcsr
    %4:fr32 = nofpexcept VSUBSSrr %2, killed %3, implicit $mxcsr
    $xmm0 = COPY %4
    RET64 implicit $xmm0

