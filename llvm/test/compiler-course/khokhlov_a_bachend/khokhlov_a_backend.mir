# Тест 6: Отрицательный тест (результат умножения используется дважды, оптимизация не должна применяться)
# CHECK-LABEL: name: test_no_fma_multiple_use
# CHECK: bb.0.entry:
# CHECK: VMULSSrr
# CHECK: VSUBSSrr
# CHECK: VADDSSrr
# CHECK: RET64 implicit $xmm0

---
name:            test_no_fma_multiple_use
alignment:       16
tracksRegLiveness: true
registers:
  - { id: 0, class: fr32 }
  - { id: 1, class: fr32 }
  - { id: 2, class: fr32 }
  - { id: 3, class: fr32 }
  - { id: 4, class: fr32 }
  - { id: 5, class: fr32 }
body:             |
  bb.0.entry:
    liveins: $xmm0, $xmm1, $xmm2, $xmm3
    %2:fr32 = COPY $xmm2
    %1:fr32 = COPY $xmm1
    %0:fr32 = COPY $xmm0
    %3:fr32 = nofpexcept VMULSSrr %0, %1, implicit $mxcsr
    %4:fr32 = nofpexcept VSUBSSrr %2, %3, implicit $mxcsr
    %5:fr32 = nofpexcept VADDSSrr %3, %4, implicit $mxcsr
    $xmm0 = COPY %5
    RET64 implicit $xmm0