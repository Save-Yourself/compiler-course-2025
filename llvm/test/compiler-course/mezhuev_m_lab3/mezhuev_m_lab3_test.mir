# Тест 5: Комплексный случай с разными типами регистров
# CHECK-LABEL: name: test_complex_register_usage
# CHECK: bb.0.entry:
# CHECK-NOT: VMULSDrr
# CHECK-NOT: VSUBSDrr
# CHECK: %[[RES:[a-z0-9]+]]:fr64 = VFMSUB213SDr %1, %2, %0, implicit $mxcsr
# CHECK: $xmm0 = COPY %[[RES]]
# CHECK: RET64 implicit $xmm0

---
name:            test_complex_register_usage
alignment:       16
tracksRegLiveness: true
registers:
  - { id: 0, class: fr64 }
  - { id: 1, class: fr64 }
  - { id: 2, class: fr64 }
  - { id: 3, class: fr64 }
  - { id: 4, class: fr64 }
body:             |
  bb.0.entry:
    liveins: $xmm0, $xmm1, $xmm2
  
    %0:fr64 = COPY $xmm0
    %1:fr64 = COPY $xmm1
    %2:fr64 = COPY $xmm2
    %3:fr64 = nofpexcept VMULSDrr %1, %2, implicit $mxcsr
    %4:fr64 = nofpexcept VSUBSDrr killed %3, %0, implicit $mxcsr
    $xmm0 = COPY %4
    RET64 implicit $xmm0
...

