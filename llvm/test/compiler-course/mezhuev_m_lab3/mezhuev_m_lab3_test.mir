...

# Тест 9: Цепочка операций — только первая часть фьюзится
# CHECK-LABEL: name: test_chain_partial_fusion
# CHECK: bb.0.entry:
# CHECK-NOT: VMULSSrr
# CHECK-NOT: VSUBSSrr
# CHECK: %[[FMA:[a-z0-9]+]]:fr32 = VFNMADD213SSr %0, %1, %2, implicit $mxcsr
# CHECK: %[[RES:[a-z0-9]+]]:fr32 = nofpexcept VADDSSrr %[[FMA]], %3, implicit $mxcsr
# CHECK: $xmm0 = COPY %[[RES]]
# CHECK: RET64 implicit $xmm0

---
name:            test_chain_partial_fusion
alignment:       16
tracksRegLiveness: true
registers:
  - { id: 0, class: fr32 }
  - { id: 1, class: fr32 }
  - { id: 2, class: fr32 }
  - { id: 3, class: fr32 }
  - { id: 4, class: fr32 }
  - { id: 5, class: fr32 }
body:             |
  bb.0.entry:
    liveins: $xmm0, $xmm1, $xmm2, $xmm3

    %0:fr32 = COPY $xmm0
    %1:fr32 = COPY $xmm1
    %2:fr32 = COPY $xmm2
    %3:fr32 = COPY $xmm3
    %4:fr32 = nofpexcept VMULSSrr %0, %1, implicit $mxcsr
    %5:fr32 = nofpexcept VSUBSSrr %2, killed %4, implicit $mxcsr
    %6:fr32 = nofpexcept VADDSSrr %5, %3, implicit $mxcsr
    $xmm0 = COPY %6
    RET64 implicit $xmm0