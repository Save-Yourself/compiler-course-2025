  - { id: 2, class: fr32 }
  - { id: 3, class: fr32 }
  - { id: 4, class: fr32 }
body:             |
  bb.0.entry:
    liveins: $xmm0, $xmm1, $xmm2

    %0:fr32 = COPY $xmm0
    %1:fr32 = COPY $xmm1
    %2:fr32 = COPY $xmm2
