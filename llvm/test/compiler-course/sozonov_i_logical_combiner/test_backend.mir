hasEHCatchret:   false
hasEHScopes:     false
hasEHFunclets:   false
isOutlined:      false
debugInstrRef:   true
failsVerification: false
tracksDebugUserValues: false
registers:
  - { id: 0, class: gr64, preferred-register: '' }
  - { id: 1, class: gr64, preferred-register: '' }
  - { id: 2, class: gr64, preferred-register: '' }
  - { id: 3, class: vr128, preferred-register: '' }
  - { id: 4, class: vr128, preferred-register: '' }
  - { id: 5, class: vr128, preferred-register: '' }
  - { id: 6, class: vr128, preferred-register: '' }
  - { id: 7, class: vr128, preferred-register: '' }
  - { id: 8, class: gr8, preferred-register: '' }
liveins:
  - { reg: '$rdi', virtual-reg: '%0' }
  - { reg: '$rsi', virtual-reg: '%1' }
  - { reg: '$rdx', virtual-reg: '%2' }
frameInfo:
  isFrameAddressTaken: false
  isReturnAddressTaken: false
  hasStackMap:     false
  hasPatchPoint:   false
  stackSize:       0
  offsetAdjustment: 0
  maxAlignment:    16
  adjustsStack:    true
  hasCalls:        true
  stackProtector:  ''
  functionContext: ''
  maxCallFrameSize: 4294967295
  cvBytesOfCalleeSavedRegisters: 0
  hasOpaqueSPAdjustment: false
  hasVAStart:      false
  hasMustTailInVarArgFunc: false
  hasTailCall:     false
  isCalleeSavedInfoValid: false
  localFrameSize:  0
  savePoint:       ''
  restorePoint:    ''
fixedStack:      []
stack:
  - { id: 0, name: __a.addr.i8, type: default, offset: 0, size: 16, alignment: 16, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 1, name: __b.addr.i9, type: default, offset: 0, size: 16, alignment: 16, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 2, name: __a.addr.i, type: default, offset: 0, size: 16, alignment: 16, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 3, name: __b.addr.i, type: default, offset: 0, size: 16, alignment: 16, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 4, name: __p.addr.i7, type: default, offset: 0, size: 8, alignment: 8, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 5, name: __p.addr.i6, type: default, offset: 0, size: 8, alignment: 8, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 6, name: __p.addr.i, type: default, offset: 0, size: 8, alignment: 8, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 7, name: a.addr, type: default, offset: 0, size: 8, alignment: 8, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 8, name: b.addr, type: default, offset: 0, size: 8, alignment: 8, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 9, name: c.addr, type: default, offset: 0, size: 8, alignment: 8, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 10, name: va, type: default, offset: 0, size: 16, alignment: 16, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 11, name: vb, type: default, offset: 0, size: 16, alignment: 16, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 12, name: vc, type: default, offset: 0, size: 16, alignment: 16, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 13, name: tmp1, type: default, offset: 0, size: 16, alignment: 16, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
  - { id: 14, name: tmp2, type: default, offset: 0, size: 16, alignment: 16, 
      stack-id: default, callee-saved-register: '', callee-saved-restored: true, 
      debug-info-variable: '', debug-info-expression: '', debug-info-location: '' }
entry_values:    []
callSites:       []
debugValueSubstitutions: []
constants:       []
machineFunctionInfo:
  amxProgModel:    None
body:             |
  bb.0.entry:
    liveins: $rdi, $rsi, $rdx

    ; CHECK: %2:gr64 = COPY $rdx
    ; CHECK-NEXT: %1:gr64 = COPY $rsi
    ; CHECK-NEXT: %0:gr64 = COPY $rdi
    ; CHECK-NEXT: MOV64mr %stack.7.a.addr, 1, $noreg, 0, $noreg, %0 :: (store (s64) into %ir.a.addr)
    ; CHECK-NEXT: MOV64mr %stack.8.b.addr, 1, $noreg, 0, $noreg, %1 :: (store (s64) into %ir.b.addr)
    ; CHECK-NEXT: MOV64mr %stack.9.c.addr, 1, $noreg, 0, $noreg, %2 :: (store (s64) into %ir.c.addr)
    ; CHECK-NEXT: MOV64mr %stack.4.__p.addr.i7, 1, $noreg, 0, $noreg, %0 :: (store (s64) into %ir.__p.addr.i7)
    ; CHECK-NEXT: %3:vr128 = MOVUPSrm %0, 1, $noreg, 0, $noreg :: (load (s128) from %ir.1, align 1)
    ; CHECK-NEXT: MOVAPSmr %stack.10.va, 1, $noreg, 0, $noreg, %3 :: (store (s128) into %ir.va)
    ; CHECK-NEXT: MOV64mr %stack.5.__p.addr.i6, 1, $noreg, 0, $noreg, %1 :: (store (s64) into %ir.__p.addr.i6)
    ; CHECK-NEXT: %4:vr128 = MOVUPSrm %1, 1, $noreg, 0, $noreg :: (load (s128) from %ir.4, align 1)
    ; CHECK-NEXT: MOVAPSmr %stack.11.vb, 1, $noreg, 0, $noreg, %4 :: (store (s128) into %ir.vb)
    ; CHECK-NEXT: MOV64mr %stack.6.__p.addr.i, 1, $noreg, 0, $noreg, %2 :: (store (s64) into %ir.__p.addr.i)
    ; CHECK-NEXT: %5:vr128 = MOVUPSrm %2, 1, $noreg, 0, $noreg :: (load (s128) from %ir.7, align 1)
    ; CHECK-NEXT: MOVAPSmr %stack.12.vc, 1, $noreg, 0, $noreg, %5 :: (store (s128) into %ir.vc)
    ; CHECK-NEXT: MOVAPSmr %stack.0.__a.addr.i8, 1, $noreg, 0, $noreg, %3 :: (store (s128) into %ir.__a.addr.i8)
    ; CHECK-NEXT: MOVAPSmr %stack.1.__b.addr.i9, 1, $noreg, 0, $noreg, %4 :: (store (s128) into %ir.__b.addr.i9)
    ; CHECK-NEXT: %6:vr128 = PXORrr %3, %4
    ; CHECK-NEXT: MOVAPSmr %stack.13.tmp1, 1, $noreg, 0, $noreg, %6 :: (store (s128) into %ir.tmp1)
    ; CHECK-NEXT: MOVAPSmr %stack.2.__a.addr.i, 1, $noreg, 0, $noreg, %6 :: (store (s128) into %ir.__a.addr.i)
    ; CHECK-NEXT: MOVAPSmr %stack.3.__b.addr.i, 1, $noreg, 0, $noreg, %5 :: (store (s128) into %ir.__b.addr.i)
    ; CHECK-NEXT: %7:vr128 = PXORrr %6, %5
    ; CHECK-NEXT: MOVAPSmr %stack.14.tmp2, 1, $noreg, 0, $noreg, %7 :: (store (s128) into %ir.tmp2)
    ; CHECK-NEXT: ADJCALLSTACKDOWN64 0, 0, 0, implicit-def dead $rsp, implicit-def dead $eflags, implicit-def dead $ssp, implicit $rsp, implicit $ssp
    ; CHECK-NEXT: $xmm0 = COPY %7
    ; CHECK-NEXT: CALL64pcrel32 @_Z11any_nonzeroDv2_x, csr_64, implicit $rsp, implicit $ssp, implicit $xmm0, implicit-def $rsp, implicit-def $ssp, implicit-def $al
    ; CHECK-NEXT: ADJCALLSTACKUP64 0, 0, implicit-def dead $rsp, implicit-def dead $eflags, implicit-def dead $ssp, implicit $rsp, implicit $ssp
    ; CHECK-NEXT: %8:gr8 = COPY $al
    ; CHECK-NEXT: $al = COPY %8
    ; CHECK-NEXT: RET 0, $al
  
    %2:gr64 = COPY $rdx
    %1:gr64 = COPY $rsi
    %0:gr64 = COPY $rdi
    MOV64mr %stack.7.a.addr, 1, $noreg, 0, $noreg, %0 :: (store (s64) into %ir.a.addr)
    MOV64mr %stack.8.b.addr, 1, $noreg, 0, $noreg, %1 :: (store (s64) into %ir.b.addr)
    MOV64mr %stack.9.c.addr, 1, $noreg, 0, $noreg, %2 :: (store (s64) into %ir.c.addr)
    MOV64mr %stack.4.__p.addr.i7, 1, $noreg, 0, $noreg, %0 :: (store (s64) into %ir.__p.addr.i7)
    %3:vr128 = MOVUPSrm %0, 1, $noreg, 0, $noreg :: (load (s128) from %ir.1, align 1)
    MOVAPSmr %stack.10.va, 1, $noreg, 0, $noreg, %3 :: (store (s128) into %ir.va)
    MOV64mr %stack.5.__p.addr.i6, 1, $noreg, 0, $noreg, %1 :: (store (s64) into %ir.__p.addr.i6)
    %4:vr128 = MOVUPSrm %1, 1, $noreg, 0, $noreg :: (load (s128) from %ir.4, align 1)
    MOVAPSmr %stack.11.vb, 1, $noreg, 0, $noreg, %4 :: (store (s128) into %ir.vb)
    MOV64mr %stack.6.__p.addr.i, 1, $noreg, 0, $noreg, %2 :: (store (s64) into %ir.__p.addr.i)
    %5:vr128 = MOVUPSrm %2, 1, $noreg, 0, $noreg :: (load (s128) from %ir.7, align 1)
    MOVAPSmr %stack.12.vc, 1, $noreg, 0, $noreg, %5 :: (store (s128) into %ir.vc)
    MOVAPSmr %stack.0.__a.addr.i8, 1, $noreg, 0, $noreg, %3 :: (store (s128) into %ir.__a.addr.i8)
    MOVAPSmr %stack.1.__b.addr.i9, 1, $noreg, 0, $noreg, %4 :: (store (s128) into %ir.__b.addr.i9)
    %6:vr128 = PXORrr %3, %4
    MOVAPSmr %stack.13.tmp1, 1, $noreg, 0, $noreg, %6 :: (store (s128) into %ir.tmp1)
    MOVAPSmr %stack.2.__a.addr.i, 1, $noreg, 0, $noreg, %6 :: (store (s128) into %ir.__a.addr.i)
    MOVAPSmr %stack.3.__b.addr.i, 1, $noreg, 0, $noreg, %5 :: (store (s128) into %ir.__b.addr.i)
    %7:vr128 = PXORrr %6, %5
    MOVAPSmr %stack.14.tmp2, 1, $noreg, 0, $noreg, %7 :: (store (s128) into %ir.tmp2)
    ADJCALLSTACKDOWN64 0, 0, 0, implicit-def dead $rsp, implicit-def dead $eflags, implicit-def dead $ssp, implicit $rsp, implicit $ssp
    $xmm0 = COPY %7
    CALL64pcrel32 @_Z11any_nonzeroDv2_x, csr_64, implicit $rsp, implicit $ssp, implicit $xmm0, implicit-def $rsp, implicit-def $ssp, implicit-def $al
    ADJCALLSTACKUP64 0, 0, implicit-def dead $rsp, implicit-def dead $eflags, implicit-def dead $ssp, implicit $rsp, implicit $ssp
    %8:gr8 = COPY $al
    $al = COPY %8
    RET 0, $al

...
