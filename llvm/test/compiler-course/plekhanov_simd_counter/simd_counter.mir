#  RUN: llc -mtriple=x86_64-unknown-linux-gnu -mattr=+avx \
#  RUN:     --load=%llvmshlibdir/SimdPass_Plekhanov_Daniil_FIIT2_BACKEND%shlibext \
#  RUN:     -run-pass=simd-counter %s -o - | FileCheck %s

# vec_ops.cpp
# // SSE2: add two 128-bit double vectors (vaddpd)
# NOINLINE void vadd_pd_128(double* dst, const double* lhs, const double* rhs) {
#     __m128d x = _mm_load_pd(lhs);
#     __m128d y = _mm_load_pd(rhs);
#     __m128d z = _mm_add_pd(x, y);
#     _mm_store_pd(dst, z);
# }
#
# // SSE2: bitwise xor over 128-bit integer vectors (pxor)
# NOINLINE void vxor_i128(int32_t* dst, const int32_t* lhs, const int32_t* rhs) {
#     __m128i x = _mm_load_si128(reinterpret_cast<const __m128i*>(lhs));
#     __m128i y = _mm_load_si128(reinterpret_cast<const __m128i*>(rhs));
#     __m128i z = _mm_xor_si128(x, y);
#     _mm_store_si128(reinterpret_cast<__m128i*>(dst), z);
# }
#
# // SSE: subtract four float elements (vsubps)
# NOINLINE void vsub_ps_128(float* dst, const float* lhs, const float* rhs) {
#     __m128 x = _mm_load_ps(lhs);
#     __m128 y = _mm_load_ps(rhs);
#     __m128 z = _mm_sub_ps(x, y);
#     _mm_store_ps(dst, z);
# }
#
# // AVX: multiply eight float elements (vmulps)
# NOINLINE void vmul_ps_256(float* dst, const float* lhs, const float* rhs) {
#     __m256 x = _mm256_load_ps(lhs);
#     __m256 y = _mm256_load_ps(rhs);
#     __m256 z = _mm256_mul_ps(x, y);
#     _mm256_store_ps(dst, z);
# }
#
# // AVX: add four double elements (vaddpd)
# NOINLINE void vadd_pd_256(double* dst, const double* lhs, const double* rhs) {
#     __m256d x = _mm256_load_pd(lhs);
#     __m256d y = _mm256_load_pd(rhs);
#     __m256d z = _mm256_add_pd(x, y);
#     _mm256_store_pd(dst, z);
# }


--- |
  ; ModuleID = 'vec_ops.ll'
  source_filename = "vec_ops.cpp"
  target datalayout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128"
  target triple = "x86_64-pc-linux-gnu"
  
  ; Function Attrs: mustprogress nofree noinline norecurse nosync nounwind willreturn memory(argmem: readwrite) uwtable
  define dso_local void @_Z11simd_add_pdPdPKdS1_(ptr nocapture noundef writeonly %0, ptr nocapture noundef readonly %1, ptr nocapture noundef readonly %2) local_unnamed_addr #0 {
    %4 = load <2 x double>, ptr %1, align 16, !tbaa !5
    %5 = load <2 x double>, ptr %2, align 16, !tbaa !5
    %6 = fadd <2 x double> %4, %5
    store <2 x double> %6, ptr %0, align 16, !tbaa !5
    ret void
  }
  
  ; Function Attrs: mustprogress nofree noinline norecurse nosync nounwind willreturn memory(argmem: readwrite) uwtable
  define dso_local void @_Z14simd_xor_si128PiPKiS1_(ptr nocapture noundef writeonly %0, ptr nocapture noundef readonly %1, ptr nocapture noundef readonly %2) local_unnamed_addr #0 {
    %4 = load <2 x i64>, ptr %1, align 16, !tbaa !5
    %5 = load <2 x i64>, ptr %2, align 16, !tbaa !5
    %6 = xor <2 x i64> %5, %4
    store <2 x i64> %6, ptr %0, align 16, !tbaa !5
    ret void
  }
  
  ; Function Attrs: mustprogress nofree noinline norecurse nosync nounwind willreturn memory(argmem: readwrite) uwtable
  define dso_local void @_Z11simd_sub_psPfPKfS1_(ptr nocapture noundef writeonly %0, ptr nocapture noundef readonly %1, ptr nocapture noundef readonly %2) local_unnamed_addr #0 {
    %4 = load <4 x float>, ptr %1, align 16, !tbaa !5
    %5 = load <4 x float>, ptr %2, align 16, !tbaa !5
    %6 = fsub <4 x float> %4, %5
    store <4 x float> %6, ptr %0, align 16, !tbaa !5
    ret void
  }
  
  ; Function Attrs: mustprogress nofree noinline norecurse nosync nounwind willreturn memory(argmem: readwrite) uwtable
  define dso_local void @_Z11simd_mul_psPfPKfS1_(ptr nocapture noundef writeonly %0, ptr nocapture noundef readonly %1, ptr nocapture noundef readonly %2) local_unnamed_addr #1 {
    %4 = load <8 x float>, ptr %1, align 32, !tbaa !5
    %5 = load <8 x float>, ptr %2, align 32, !tbaa !5
    %6 = fmul <8 x float> %4, %5
    store <8 x float> %6, ptr %0, align 32, !tbaa !5
    ret void
  }
  
  ; Function Attrs: mustprogress nofree noinline norecurse nosync nounwind willreturn memory(argmem: readwrite) uwtable
  define dso_local void @_Z14simd_add_pd256PdPKdS1_(ptr nocapture noundef writeonly %0, ptr nocapture noundef readonly %1, ptr nocapture noundef readonly %2) local_unnamed_addr #1 {
    %4 = load <4 x double>, ptr %1, align 32, !tbaa !5
    %5 = load <4 x double>, ptr %2, align 32, !tbaa !5
    %6 = fadd <4 x double> %4, %5
    store <4 x double> %6, ptr %0, align 32, !tbaa !5
    ret void
  }
  
  attributes #0 = { mustprogress nofree noinline norecurse nosync nounwind willreturn memory(argmem: readwrite) uwtable "min-legal-vector-width"="128" "no-trapping-math"="true" "stack-protector-buffer-size"="8" "target-cpu"="x86-64" "target-features"="+avx,+cmov,+crc32,+cx8,+fxsr,+mmx,+popcnt,+sse,+sse2,+sse3,+sse4.1,+sse4.2,+ssse3,+x87,+xsave,+avx" "tune-cpu"="generic" }
  attributes #1 = { mustprogress nofree noinline norecurse nosync nounwind willreturn memory(argmem: readwrite) uwtable "min-legal-vector-width"="256" "no-trapping-math"="true" "stack-protector-buffer-size"="8" "target-cpu"="x86-64" "target-features"="+avx,+cmov,+crc32,+cx8,+fxsr,+mmx,+popcnt,+sse,+sse2,+sse3,+sse4.1,+sse4.2,+ssse3,+x87,+xsave,+avx" "tune-cpu"="generic" }
  
  !llvm.module.flags = !{!0, !1, !2, !3}
  !llvm.ident = !{!4}
  
  !0 = !{i32 1, !"wchar_size", i32 4}
  !1 = !{i32 8, !"PIC Level", i32 2}
  !2 = !{i32 7, !"PIE Level", i32 2}
  !3 = !{i32 7, !"uwtable", i32 2}
  !4 = !{!"Ubuntu clang version 18.1.3 (1ubuntu1)"}
  !5 = !{!6, !6, i64 0}
  !6 = !{!"omnipotent char", !7, i64 0}
  !7 = !{!"Simple C++ TBAA"}

...
